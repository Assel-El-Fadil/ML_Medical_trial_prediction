# ============================================================
#  Dockerfile pour le service UI — Streamlit
# ============================================================

FROM python:3.11-slim

LABEL description="Interface Streamlit pour le Clinical Trial Completion Predictor"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Installer Streamlit et le client HTTP
RUN pip install --no-cache-dir streamlit==1.35.0 requests==2.32.3

# Copier l'interface Streamlit
COPY app/streamlit_app.py ./app/streamlit_app.py

EXPOSE 8501

CMD ["streamlit", "run", "app/streamlit_app.py", "--server.port", "8501", "--server.address", "0.0.0.0"]
